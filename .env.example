LLM_API_KEY=

# Azure OpenAI / Foundry with Entra (optional): set LLM_AZURE_USE_ENTRA_ID=true and omit LLM_API_KEY
LLM_AZURE_USE_ENTRA_ID=true
LLM_AZURE_ENTRA_CREDENTIAL=client_secret
LLM_API_TYPE=openai
LLM_API_PLATFORM=azure
LLM_API_BASE=https://<resource>.openai.azure.com/
LLM_API_VERSION=2024-12-01-preview
LLM_DEPLOYMENT_ID=
MODEL=usually_same_as_LLM_DEPLOYMENT_ID
# One of: default | client_secret
LLM_AZURE_ENTRA_SCOPE=https://ai.azure.com/.default
# Classic *.openai.azure.com often: LLM_AZURE_ENTRA_SCOPE=https://cognitiveservices.azure.com/.default

# --- Per-mode Entra credential parameters (no OS env / file auto-discovery) ---
# All fields below are taken straight from configuration; the Azure SDK is NOT
# allowed to consult OS env, az CLI cache or IDE state for these values.

# Required for client_secret mode:
LLM_AZURE_TENANT_ID=
# Required for client_secret mode.
LLM_AZURE_CLIENT_ID=

# client_secret mode:
LLM_AZURE_CLIENT_SECRET=<FILL_ME_CLIENT_SECRET>

# Root for app templates
PROMPT_TEMPLATES_PATH=tpl

# Writeable directory for app working files
STORAGE_PATH=storage

# Encoding for text files
MC_DEFAULT_ENCODING=utf-8

# Optional, required to use microcore.text2speech.elevenlabs
ELEVENLABS_API_KEY=
