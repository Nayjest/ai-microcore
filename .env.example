LLM_API_KEY=

# Azure OpenAI / Foundry with Entra (optional): set LLM_AZURE_USE_ENTRA_ID=true and omit LLM_API_KEY
LLM_AZURE_USE_ENTRA_ID=false
LLM_AZURE_ENTRA_CREDENTIAL=default
LLM_AZURE_ENTRA_SCOPE=https://ai.azure.com/.default
# Classic *.openai.azure.com often: LLM_AZURE_ENTRA_SCOPE=https://cognitiveservices.azure.com/.default
# User-assigned MI: LLM_AZURE_ENTRA_CREDENTIAL=managed_identity and AZURE_CLIENT_ID=<client-id>

# Root for app templates
PROMPT_TEMPLATES_PATH=tpl

# Writeable directory for app working files
STORAGE_PATH=storage

# Encoding for text files
MC_DEFAULT_ENCODING=utf-8

# Optional, required to use microcore.text2speech.elevenlabs
ELEVENLABS_API_KEY=